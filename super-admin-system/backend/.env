# Server Configuration
NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:3001

# Database (SAME database connection)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=unieat_db
DB_USER=postgres
DB_PASSWORD=mac123

# JWT for Super Admin System (DIFFERENT secret!)
SUPER_ADMIN_JWT_SECRET=super_admin_different_secret_key_here
JWT_EXPIRES_IN=30d

# CORS (allow both systems)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Super Admin specific
SUPER_ADMIN_EMAIL=superadmin@unieat.com
SUPER_ADMIN_PASSWORD_HASH=hashed_password_here

# Logging
LOG_LEVEL=info