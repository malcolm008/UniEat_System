# Server
NODE_ENV=development
PORT=5000

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=unieat_db
DB_USER=postgres
DB_PASSWORD=mac123

# JWT Secrets  (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# QR Code
QR_EXPIRY_MINUTES=30

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS — frontend origins (comma separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=info

# Hovercode API Credentials
HOVERCODE_WORKSPACE=16d7f3bd-f8dd-46f4-9703-df9be3773efa
HOVERCODE_TOKEN=4d4d46f28f23480feaea8d175f2879a48aa92aab